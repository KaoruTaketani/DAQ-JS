{
    "compilerOptions": {
        "target": "es2022",
        // specifies the module system, when generating module code
        // "module": "node16", // necessary for import.meta 
        "module": "es2022", 
        // "module": "NodeNext", 
        // specifies how modules are resolved for imports.
        // "moduleResolution": "nodenext", // necessary for only import('h5wasm')? but if module is node16, it seems to be unnecessary
        "checkJs": true,
        // following from  tsoptions?
        "strict": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        // "baseUrl": "."
    },
    "exclude": ["node_modules"]
}